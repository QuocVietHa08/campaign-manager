{
  "name": "@campaign-manager/backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "sequelize-cli db:migrate",
    "db:seed": "sequelize-cli db:seed:all",
    "db:migrate:undo": "sequelize-cli db:migrate:undo:all",
    "test": "NODE_ENV=test jest --runInBand --forceExit"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "sequelize": "^6.37.0",
    "pg": "^8.13.0",
    "pg-hstore": "^2.3.4",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "zod": "^3.23.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "sequelize-cli": "^6.6.0",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "@types/jest": "^29.5.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0"
  }
}
